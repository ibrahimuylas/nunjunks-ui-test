{% extends "demo/layouts/main.njk" %}
{% from "govuk/components/notification-banner/macro.njk" import govukNotificationBanner %}
{% from "govuk/components/pagination/macro.njk" import govukPagination %}
{% from "govuk/components/table/macro.njk" import govukTable %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/tag/macro.njk" import govukTag %}

{% macro queueTable(table) %}
  {% set rows = [] %}
  {% for row in table.rows %}
    {% set referenceHtml %}<a class="govuk-link" href="{{ row.requestHref }}">{{ row.reference }}</a>{% endset %}
    {% set statusHtml %}{{ govukTag(row.statusTag) }}{% endset %}
    {% set tableRow = [
      { html: referenceHtml },
      { text: row.applicantAlias },
      { text: row.receivedDate },
      { text: row.urgency },
      { html: statusHtml }
    ] %}
    {% set ignored = rows.push(tableRow) %}
  {% endfor %}
  <div
    class="app-casework-queue-table"
    role="region"
    aria-label="{{ table.caption }}"
    tabindex="0"
  >
    {{ govukTable({
      caption: table.caption,
      captionClasses: "govuk-table__caption--m",
      classes: "app-casework-queue-table__table",
      firstCellIsHeader: true,
      head: table.head,
      rows: rows
    }) }}
  </div>
  {% if table.pagination %}
    {{ govukPagination(table.pagination) }}
  {% endif %}
{% endmacro %}

{% block content %}
  <h1 class="govuk-heading-xl">{{ heading }}</h1>
  <p class="govuk-body-l">Review fictional emergency housing support requests.</p>

  {{ govukNotificationBanner(notificationBanner) }}

  <nav aria-label="Filter fictional requests" class="govuk-!-margin-bottom-6">
    <ul class="govuk-list govuk-list--inline">
      {% for item in filterLinks %}
        <li>
          <a class="govuk-link" href="{{ item.href }}"{% if item.current %} aria-current="page"{% endif %}>{{ item.text }}</a>
        </li>
      {% endfor %}
    </ul>
  </nav>

  {% set tabItems = [] %}
  {% for item in tabs.items %}
    {% set panelHtml %}{{ queueTable(item.table) }}{% endset %}
    {% set ignored = tabItems.push({
      id: item.id,
      label: item.label,
      panel: { html: panelHtml }
    }) %}
  {% endfor %}

  {{ govukTabs({
    idPrefix: tabs.idPrefix,
    title: tabs.title,
    items: tabItems
  }) }}
{% endblock %}
