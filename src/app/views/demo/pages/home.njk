{% extends "demo/layouts/main.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-xl">Choose a fictional service journey</h1>
      <p class="govuk-body-l">Explore GOV.UK components in two connected demonstration journeys.</p>

      <p class="govuk-body"><strong>This service is fictional.</strong> It does not provide emergency housing support or make casework decisions.</p>
      <p class="govuk-body"><strong>Do not enter real personal information or passwords.</strong> Use made-up information only.</p>

      <h2 class="govuk-heading-m">Request emergency housing support</h2>
      <p class="govuk-body">Act as a member of the public making a fictional support request.</p>
      <p class="govuk-body"><a class="govuk-link" href="/demo/support/start">Explore the public journey</a></p>

      <h2 class="govuk-heading-m">Triage support requests</h2>
      <p class="govuk-body">Act as a fictional caseworker reviewing demonstration records.</p>
      <p class="govuk-body"><a class="govuk-link" href="/demo/casework/sign-in">Explore the caseworker journey</a></p>
    </div>
  </div>
{% endblock %}
