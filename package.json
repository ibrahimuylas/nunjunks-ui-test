{
  "name": "govuk-defra-nunjucks-example",
  "version": "1.0.0",
  "description": "A GOV.UK Frontend style Express and Nunjucks example journey.",
  "main": "src/app/server.js",
  "scripts": {
    "dev": "nodemon src/app/server.js",
    "start": "node src/app/server.js",
    "build": "npm run build:css && npm run build:js",
    "build:css": "sass --load-path=node_modules src/app/public/stylesheets/application.scss src/app/public/stylesheets/application.css --style=compressed",
    "build:js": "node scripts/copy-assets.js",
    "test": "jest --runInBand",
    "test:browser": "npm run build && playwright test --config=tests/browser/playwright.config.js",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "jest": {
    "testPathIgnorePatterns": [
      "<rootDir>/tests/browser/"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "govuk-frontend": "^5.4.1",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.6.0",
    "@playwright/test": "^1.61.1",
    "eslint": "^9.6.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "sass": "^1.77.8",
    "supertest": "^7.0.0"
  }
}
